@model LoginValidationModel
@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Prijavi se (Login)</h3>
                </div>
                <div class="card-body">
                    @if (ViewBag.Greska != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Greska
                        </div>
                    }

                    <form asp-action="Login" method="POST">
                        <div class="mb-3">
                            <label asp-for="UsernameOrEmail" class="form-label">Username ili Email:</label>
                            <input asp-for="UsernameOrEmail" class="form-control" placeholder="Unesite username ili email" />
                            <span asp-validation-for="UsernameOrEmail" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Password:</label>
                            <input asp-for="Password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger small fw-bold"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Prijavi se</button>
                    </form>
                </div>
                <div class="card-footer text-center text-muted">
                    Nemate nalog? <a asp-action="Register" class="text-primary font-weight-bold">Registrujte se</a>
                </div>
            </div>
        </div>
    </div>
</div>