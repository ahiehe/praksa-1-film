@model praktika1.Models.Film

@{
    ViewData["Title"] = "Detalji o filmu";
}

<div class="container mt-5" style="max-width: 600px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Nazad na listu</a>
       
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header bg-dark text-white text-center py-3">
            <h2 class="mb-0">@Model.Naziv</h2>
        </div>
        <div class="card-body">
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <strong>Godina izdanja:</strong>
                    <span>@Model.GodinaIzdanja. god.</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <strong>Žanr:</strong>
                    <span class="badge bg-secondary px-2 py-1">@Model.Zanr.Naziv</span>
                </li>
                <li class="list-group-item">
                    <strong>Režiser(i):</strong>
                    <div class="mt-1 text-muted">
                        @string.Join(", ", Model.Reziseri.Select(r => $"{r.Ime} {r.Prezime}"))
                    </div>
                </li>
                <li class="list-group-item">

                     @Model.Opis
      
                </li>
            </ul>
        </div>
        <div class="card-footer bg-light text-end">
            <small class="text-muted">ID filma: @Model.Id</small>
        </div>
    </div>

    @if (Context.Session.GetString("Role") == "Admin")
    {

        <div class="card shadow-sm border-warning">
            <div class="card-body d-flex justify-content-between align-items-center py-2 bg-light">
                <span class="text-muted fw-bold small text-uppercase">Upravljanje filmom:</span>
                <div class="d-flex gap-2">
                    <a asp-action="UpdateFilm" asp-route-id="@Model.Id" class="btn btn-warning btn-sm fw-bold">
                        Izmeni
                    </a>

                    <form asp-action="DeleteFilm" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Da li ste sigurni da želite da obrišete ovaj film?');"
                          class="d-inline">
                        <button type="submit" class="btn btn-danger btn-sm fw-bold">
                            Obriši
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
    
</div>