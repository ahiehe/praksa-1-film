@model praktika1.Models.Film

@{
    ViewData["Title"] = "Dodaj novi film";
}

<div class="container mt-5" style="max-width: 500px;">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white text-center py-3">
            <h3 class="mb-0">Dodaj novi film</h3>
        </div>
        <div class="card-body p-4">

            <form asp-action="CreateFilm" method="post">
                <div asp-validation-summary="All" class="text-danger fw-bold mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Naziv" class="form-label">Naziv filma</label>
                    <input asp-for="Naziv" class="form-control" placeholder="Unesite naziv..." />
                    <span asp-validation-for="Naziv" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Opis" class="form-label">Opis filma</label>
                    <input asp-for="Opis" class="form-control" placeholder="Unesite opis..." />
                    <span asp-validation-for="Opis" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="GodinaIzdanja" class="form-label">Godina izdanja</label>
                    <input asp-for="GodinaIzdanja" type="number" class="form-control" placeholder="npr. 2024" />
                    <span asp-validation-for="GodinaIzdanja" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ZanrId" class="form-label">Žanr</label>
                    <select asp-for="ZanrId" class="form-select" asp-items="ViewBag.ZanrId">
                        <option value="">-- Izaberite žanr --</option>
                    </select>
                    <span asp-validation-for="ZanrId" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Režiser(i)</label>
                    <select name="izabraniReziseri" class="form-select" multiple asp-items="ViewBag.ReziseriId" style="height: 120px;">
                    </select>
                    <span class="text-muted small">Držite Ctrl da izaberete više režisera.</span>
                </div>

                <div class="d-flex justify-content-between align-items-center pt-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">Nazad</a>
                    <button type="submit" class="btn btn-success px-4">Sačuvaj</button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}