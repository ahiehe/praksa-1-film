@model List<praktika1.Models.Film>

@{
    ViewData["Title"] = "Lista filmova";

    int trenutnaStranica = ViewBag.TrenutnaStranica ?? 1;
    int ukupnoStranica = ViewBag.UkupnoStranica ?? 1;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5">Lista filmova</h1>
         @if (Context.Session.GetString("Role") == "Admin")
         {
            <a class="btn btn-primary" asp-action="CreateFilm">Dodaj novi film</a>
         }
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
            @foreach (var film in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 bg-light">
                        <div class="card-header bg-dark text-white py-3">
                            <h5 class="card-title mb-0 text-truncate">@film.Naziv</h5>
                        </div>
                        <div class="card-body bg-white">
                            <p class="card-text mb-2">
                                <strong>Godina izdanja:</strong> <span class="text-muted">@film.GodinaIzdanja. god.</span>
                            </p>
                            <p class="card-text mb-2">
                                <strong>Žanr:</strong>
                                <span class="badge bg-secondary">@film.Zanr.Naziv</span>
                            </p>
                            <p class="card-text mb-0">
                                <strong>Režiser(i):</strong>
                            </p>
                            <p class="text-muted small text-truncate mb-2">
                                @string.Join(", ", film.Reziseri.Select(r => $"{r.Ime} {r.Prezime}"))
                            </p>

                            <hr class="my-2 text-muted-50">
                            <p class="card-text small text-secondary">
                                @if (film.Opis?.Length > 150)
                                {
                                    @(film.Opis.Substring(0, 150) + "...")
                                }
                                else
                                {
                                    @film.Opis
                                }
                            </p>
                        </div>
                        <div class="card-footer bg-light d-flex justify-content-between align-items-center py-2">
                            <a asp-action="DetailsFilm" asp-route-id="@film.Id" class="btn btn-outline-primary btn-sm">Detalji</a>
                            @if (Context.Session.GetString("Role") == "Admin")
                            {
                                <form asp-action="DeleteFilm" asp-route-id="@film.Id" method="post"
                                onsubmit="return confirm('Da li ste sigurni da želite da obrišete ovaj film?');" class="d-inline">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Obrisi</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (ukupnoStranica > 1)
        {
            <nav aria-label="Navigacija po stranicama" class="d-flex justify-content-center mt-4">
                <ul class="pagination shadow-sm">

                    <li class="page-item @(trenutnaStranica == 1 ? "disabled" : "")">
                        <a class="page-item page-link" asp-action="Index" asp-route-page="@(trenutnaStranica - 1)">« Prethodna</a>
                    </li>

                    @for (int i = 1; i <= ukupnoStranica; i++)
                    {
                        <li class="page-item @(i == trenutnaStranica ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                        </li>
                    }

                    <li class="page-item @(trenutnaStranica == ukupnoStranica ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@(trenutnaStranica + 1)">Sledeća »</a>
                    </li>

                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info text-center shadow-sm" role="alert">
            Trenutno nema filmova u bazi podataka.
        </div>
    }
</div>