@model RegisterValidationModel
@{
    ViewData["Title"] = "Register";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">Registracija (Register)</h3>
                </div>
                <div class="card-body">

                    <form asp-action="Register" method="POST">

                        <div class="mb-3">
                            <label asp-for="Username" class="form-label">Username:</label>
                            <input asp-for="Username" class="form-control" />
                            <span asp-validation-for="Username" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email:</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Password:</label>
                            <input asp-for="Password" type="password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger small fw-bold"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100 mt-2">Registruj se</button>
                    </form>

                </div>
                <div class="card-footer text-center text-muted">
                    Već imate nalog? <a asp-action="Login" class="text-success font-weight-bold">Prijavite se</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}